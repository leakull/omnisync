# Database
POSTGRES_DB=omnisync
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
SYNC_DATABASE_URL=postgresql://postgres:changeme@localhost:5432/omnisync
DATABASE_URL=postgresql+asyncpg://postgres:changeme@localhost:5432/omnisync

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0

# GitHub
GITHUB_TOKEN=ghp_your_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret
GITHUB_SYNC_OWNER=your-org
GITHUB_SYNC_REPO=your-repo

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret

# JWT
JWT_SECRET=changeme-min-32-chars-placeholder

# S3/MinIO
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=omnisync-raw-payloads

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317

# App
ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
