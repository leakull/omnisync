# Database
POSTGRES_DB=omnisync
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
SYNC_DATABASE_URL=postgresql://postgres:changeme@localhost:5432/omnisync
DATABASE_URL=postgresql+asyncpg://postgres:changeme@localhost:5432/omnisync

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0

# GitHub
GITHUB_TOKEN=ghp_your_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret
GITHUB_SYNC_OWNER=your-org
GITHUB_SYNC_REPO=your-repo

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret

# IMAP (inbound email)
IMAP_HOST=
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX
IMAP_USE_SSL=true

# SMTP (outbound email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM=

# JWT
JWT_SECRET=changeme-min-32-chars-placeholder

# S3/MinIO
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=omnisync-raw-payloads

# File storage source connector (S3/MinIO bucket as a source)
FILESTORE_ENDPOINT_URL=
FILESTORE_ACCESS_KEY=
FILESTORE_SECRET_KEY=
FILESTORE_BUCKET=
FILESTORE_PREFIX=
FILESTORE_REGION=us-east-1

# Jira (task tracker) connector
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT=
JIRA_PAGE_SIZE=50

# Vector search / embeddings
QDRANT_URL=http://localhost:6333
# Backend: local (sentence-transformers) | openai | fake
EMBEDDING_BACKEND=local
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384
# Only needed when EMBEDDING_BACKEND=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
JAEGER_HEALTH_URL=http://jaeger:16686/

# Secrets: directory of file-based secrets (Docker/K8s). When present, each
# setting may be supplied as a file named after the env var (e.g. JWT_SECRET).
SECRETS_DIR=/run/secrets

# Dead-letter queue auto-retry (exponential backoff)
DLQ_MAX_REPLAY_ATTEMPTS=5
DLQ_RETRY_ENABLED=true
DLQ_RETRY_INTERVAL=60
DLQ_RETRY_BASE_DELAY=60
DLQ_RETRY_MAX_DELAY=3600
DLQ_RETRY_BATCH_SIZE=50

# Monitoring (docker compose --profile monitoring)
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# App
ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
